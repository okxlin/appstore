CONTAINER_NAME=
PANEL_APP_PORT_HTTP=80
PANEL_APP_PORT_HTTPS=443
CONFIG_PATH=./data/config
LOCAL_DOMAIN=example.com
WEB_DOMAIN=
REDIS_HOST=mastodon-redis
REDIS_PORT=6379
DB_HOST=mastodon-db
DB_PORT=5432
DB_USER=mastodon
DB_NAME=mastodon
DB_PASSWORD=replace-with-db-password
ACTIVE_RECORD_ENCRYPTION_PRIMARY_KEY=replace-with-generated-active-record-primary-key
ACTIVE_RECORD_ENCRYPTION_DETERMINISTIC_KEY=replace-with-generated-active-record-deterministic-key
ACTIVE_RECORD_ENCRYPTION_KEY_DERIVATION_SALT=replace-with-generated-active-record-salt
SECRET_KEY_BASE=replace-with-generated-secret-key-base
OTP_SECRET=replace-with-generated-otp-secret
VAPID_PRIVATE_KEY=replace-with-generated-vapid-private-key
VAPID_PUBLIC_KEY=replace-with-generated-vapid-public-key
SMTP_SERVER=mail.example.com
SMTP_PORT=25
SMTP_LOGIN=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=notifications@example.com
MASTODON_PROMETHEUS_EXPORTER_ENABLED=false
SIDEKIQ_THREADS=5
DB_POOL=5
DB_DATA_PATH=./data/db
REDIS_DATA_PATH=./data/redis
TIME_ZONE=Asia/Shanghai
