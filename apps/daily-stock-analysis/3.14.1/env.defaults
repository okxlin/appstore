# ===================================
# 每日股票分析 - 容器环境变量
# 所有功能（LLM/通知/报告/定时/策略）均可在 WebUI 内配置
# 此文件挂载为 /app/.env，应用直接读取
# ===================================

# --- 管理员认证 ---
ADMIN_AUTH_ENABLED=true

# --- Docker 服务模式 ---
WEBUI_PORT=8000
WEBUI_AUTO_BUILD=true

# --- 数据与日志 ---
DATABASE_PATH=/app/data/stock_analysis.db
LOG_DIR=/app/logs
LOG_LEVEL=INFO
MAX_WORKERS=3
DEBUG=false

# --- SQLite 优化 ---
SQLITE_WAL_ENABLED=true
SQLITE_BUSY_TIMEOUT_MS=5000
SQLITE_WRITE_RETRY_MAX=3
SQLITE_WRITE_RETRY_BASE_DELAY=0.1

# --- 搜索 ---
SEARXNG_PUBLIC_INSTANCES_ENABLED=true

# --- Stream 模式（默认关闭）---
DINGTALK_STREAM_ENABLED=false
FEISHU_STREAM_ENABLED=false

# ===================================
# 以下为可选参考变量（取消注释即可启用）
# ===================================
# Agent 默认启用策略（留空使用内置默认 bull_trend）
AGENT_SKILLS=
# AGENT_SKILL_DIR=./strategies
# AGENT_ARCH=single
# AGENT_ORCHESTRATOR_MODE=standard
# AGENT_ORCHESTRATOR_TIMEOUT_S=600
# AGENT_RISK_OVERRIDE=true
# AGENT_MEMORY_ENABLED=false
# AGENT_SKILL_AUTOWEIGHT=true
# AGENT_SKILL_ROUTING=auto

# LLM 多渠道配置
# LLM_CHANNELS=deepseek,gemini
# LLM_DEEPSEEK_API_KEY=sk-xxx
# LLM_DEEPSEEK_BASE_URL=https://api.deepseek.com
# LLM_DEEPSEEK_MODELS=deepseek-v4-flash,deepseek-v4-pro
# LLM_TEMPERATURE=0.7
# LITELLM_CONFIG=./litellm_config.yaml

# 搜索引擎（不在表单中）
# BOCHA_API_KEYS=
# MINIMAX_API_KEYS=
# BRAVE_API_KEYS=
# SEARXNG_BASE_URLS=

# 社交舆情（仅美股）
# SOCIAL_SENTIMENT_API_KEY=
# SOCIAL_SENTIMENT_API_URL=https://api.adanos.org

# 新闻时效与筛选
# NEWS_STRATEGY_PROFILE=short
# NEWS_MAX_AGE_DAYS=3
# BIAS_THRESHOLD=5.0

# 通知渠道高级配置
# FEISHU_WEBHOOK_KEYWORD=股票日报
# TELEGRAM_MESSAGE_THREAD_ID=
# DISCORD_BOT_TOKEN=
# DISCORD_MAIN_CHANNEL_ID=
# SLACK_WEBHOOK_URL=
# CUSTOM_WEBHOOK_BEARER_TOKEN=
# WEBHOOK_VERIFY_SSL=true
# PUSHOVER_USER_KEY=
# PUSHOVER_API_TOKEN=
# PUSHPLUS_TOPIC=
# FEISHU_MAX_BYTES=20000
# WECHAT_MAX_BYTES=4000
# MARKDOWN_TO_IMAGE_CHANNELS=
# MARKDOWN_TO_IMAGE_MAX_CHARS=15000
# MD2IMG_ENGINE=wkhtmltoimage
# PREFETCH_REALTIME_QUOTES=true
# MERGE_EMAIL_NOTIFICATION=false

# 飞书 Stream / 应用模式
# FEISHU_APP_ID=
# FEISHU_APP_SECRET=

# 钉钉 Stream 模式
# DINGTALK_APP_KEY=
# DINGTALK_APP_SECRET=

# 报告引擎高级配置
# REPORT_TEMPLATES_DIR=templates
# REPORT_RENDERER_ENABLED=false
# REPORT_INTEGRITY_ENABLED=true
# REPORT_INTEGRITY_RETRY=1
# REPORT_HISTORY_COMPARE_N=0

# 回测高级配置
# BACKTEST_EVAL_WINDOW_DAYS=10
# BACKTEST_MIN_AGE_DAYS=14
# BACKTEST_ENGINE_VERSION=v1
# BACKTEST_NEUTRAL_BAND_PCT=2.0

# 大盘复盘区域
# MARKET_REVIEW_REGION=cn

# 数据源
# TICKFLOW_API_KEY=
# LONGBRIDGE_APP_KEY=
# LONGBRIDGE_APP_SECRET=
# LONGBRIDGE_ACCESS_TOKEN=
# LONGBRIDGE_STATIC_INFO_TTL_SECONDS=86400
# LONGBRIDGE_ENABLE_OVERNIGHT=false
# LONGBRIDGE_PUSH_CANDLESTICK_MODE=realtime
# LONGBRIDGE_PRINT_QUOTE_PACKAGES=false

# Data Fetcher 优先级
# EFINANCE_PRIORITY=0
# EFINANCE_CALL_TIMEOUT=30
# AKSHARE_PRIORITY=1
# TUSHARE_PRIORITY=2
# PYTDX_PRIORITY=2
# BAOSTOCK_PRIORITY=3
# YFINANCE_PRIORITY=4

# 实时行情
# REALTIME_SOURCE_PRIORITY=tencent,akshare_sina,efinance,akshare_em
# ENABLE_REALTIME_QUOTE=true
# ENABLE_REALTIME_TECHNICAL_INDICATORS=true
# ENABLE_CHIP_DISTRIBUTION=true
# ENABLE_FUNDAMENTAL_PIPELINE=true
# FUNDAMENTAL_STAGE_TIMEOUT_SECONDS=1.5
# FUNDAMENTAL_FETCH_TIMEOUT_SECONDS=0.8
# FUNDAMENTAL_RETRY_MAX=1
# FUNDAMENTAL_CACHE_TTL_SECONDS=120
# FUNDAMENTAL_CACHE_MAX_ENTRIES=256

# 代理
# USE_PROXY=false
# PROXY_HOST=127.0.0.1
# PROXY_PORT=10809

# Portfolio 风控
# PORTFOLIO_RISK_CONCENTRATION_ALERT_PCT=35.0
# PORTFOLIO_RISK_DRAWDOWN_ALERT_PCT=15.0
# PORTFOLIO_RISK_STOP_LOSS_ALERT_PCT=10.0
# PORTFOLIO_RISK_STOP_LOSS_NEAR_RATIO=0.8
# PORTFOLIO_RISK_LOOKBACK_DAYS=180
# PORTFOLIO_FX_UPDATE_ENABLED=true
# ENABLE_EASTMONEY_PATCH=false
