CONTAINER_NAME=elizabeth
PANEL_APP_PORT_HTTP=4092
JWT_SECRET=replace-with-a-long-random-secret-min-32-chars  # pragma: allowlist secret
DATABASE_URL=sqlite:///app/data/elizabeth.db
ROOM_MAX_SIZE=50MiB
ROOM_MAX_TIMES_ENTERED=100
ROOM_ALLOWED_AGES=1m,30m,2h,12h,1d,7d,30d,365d
ROOM_DEFAULT_AGE=2h
ROOM_SHARE_DISABLED_LOCK_DURATION=1h
APP_DATA_DIR=./data
APP_STORAGE_DIR=./storage
TZ=Asia/Shanghai
