PANEL_APP_PORT_HTTP=4096
PANEL_APP_PORT_ACP=8765
CONTAINER_NAME=opencode-workstation
TZ=Asia/Shanghai
DOCKER_SOCK_SRC=/var/run/docker.sock
APP_DATA_DIR_1=./data/workspace
APP_DATA_DIR_2=./data/config
APP_DATA_DIR_3=./data/cache
APP_DATA_DIR_4=./data/runtime
