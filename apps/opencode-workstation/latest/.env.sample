OPENCODE_SERVER_PASSWORD=
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=
GEMINI_API_KEY=
GEMINI_BASE_URL=
GITHUB_TOKEN=
